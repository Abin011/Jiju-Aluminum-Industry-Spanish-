---
import { site } from '../data/site';
---

<form
  class="contact-form"
  id="contact-form"
  data-webmcp-form="lead-capture"
  aria-label="Formulario de solicitud de presupuesto"
  action="https://api.staticforms.dev/submit"
  method="POST"
>
  <input type="hidden" name="apiKey" value="sf_70729816317ecbbc45e9f246" />
  <input type="hidden" name="subject" value="Nueva consulta desde JIJU Aluminium España" />
  <input type="hidden" name="replyTo" value="@" />
  <input type="hidden" name="redirectTo" value={`${site.url}/thank-you/`} />
  <div class="form-row">
    <label for="name">Nombre</label>
    <input id="name" name="name" type="text" autocomplete="name" required />
  </div>
  <div class="form-row">
    <label for="email">Email</label>
    <input id="email" name="email" type="email" autocomplete="email" required />
  </div>
  <div class="form-row">
    <label for="company">Empresa</label>
    <input id="company" name="company" type="text" autocomplete="organization" />
  </div>
  <div class="form-row">
    <label for="country">País</label>
    <input id="country" name="country" type="text" autocomplete="country-name" value="España" />
  </div>
  <div class="form-row full">
    <label for="product">Producto o aplicación</label>
    <input id="product" name="product" type="text" required placeholder="Perfil a medida, puerta y ventana, LED, nueva energía..." />
  </div>
  <div class="form-row full">
    <label for="requirements">Planos, especificaciones o mensaje</label>
    <textarea id="requirements" name="message" rows="6" required></textarea>
  </div>
  <button type="submit" data-default-label="Solicitar presupuesto" data-sending-label="Enviando solicitud...">
    Solicitar presupuesto
  </button>
  <p>También puede escribir a <a href={`mailto:${site.email}`}>{site.email}</a> o por <a href={site.whatsappUrl}>WhatsApp</a>.</p>
</form>

<script>
  const form = document.querySelector<HTMLFormElement>('#contact-form');
  const submitButton = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
  const cooldownMs = 60 * 1000;
  const storageKey = 'jiju-inquiry-last-submit';

  const setSubmitDisabled = (disabled: boolean, label?: string) => {
    if (!submitButton) return;

    submitButton.disabled = disabled;
    submitButton.textContent = label ?? submitButton.dataset.defaultLabel ?? 'Solicitar presupuesto';
  };

  const getRemainingCooldown = () => {
    const lastSubmit = Number(window.localStorage.getItem(storageKey) ?? 0);
    return Math.max(0, cooldownMs - (Date.now() - lastSubmit));
  };

  const updateCooldownState = () => {
    const remaining = getRemainingCooldown();

    if (remaining <= 0) {
      setSubmitDisabled(false);
      return;
    }

    const seconds = Math.ceil(remaining / 1000);
    setSubmitDisabled(true, `Espere ${seconds}s para reenviar`);
    window.setTimeout(updateCooldownState, 1000);
  };

  updateCooldownState();

  form?.addEventListener('submit', () => {
    window.localStorage.setItem(storageKey, String(Date.now()));
    setSubmitDisabled(true, submitButton?.dataset.sendingLabel);
  });
</script>
